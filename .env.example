# Google Sheets via Apps Script (no Google Cloud Console needed)

# 1. Create a Google Sheet with tabs: Profile, Projects, Admin
# 2. Extensions -> Apps Script -> paste apps-script.gs -> Deploy > New deployment
# 3. Set type to "Web app", Execute as "Me", Access "Anyone"
# 4. Copy the web app URL here:
APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbyTv2TfJyTKBU2etH5GCHbrB_6Vju_5hOyNJghXDGTTLEbw7Emhr8guTUCzGMYlYyq6_g/exec

# Optional: set a secret token in the script and here for write protection
API_TOKEN=my-name-is-piseth-7979-is-a-string
